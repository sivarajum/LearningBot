# Medallion Architecture -- Environment Configuration
# Copy to .env and adjust values as needed.

# -- Paths ------------------------------------------------------------------
# PROJECT_ROOT=/app
# RAW_DATA_PATH=/app/data/raw
# DUCKDB_PATH=/app/data/warehouse.duckdb

# -- Server -----------------------------------------------------------------
# API_HOST=0.0.0.0
# API_PORT=8000
# UI_PORT=8501

# -- CORS -------------------------------------------------------------------
# Comma-separated origins allowed by the API
# CORS_ORIGINS=http://localhost:3000,http://localhost:8501

# -- Logging ----------------------------------------------------------------
# LOG_LEVEL=INFO
