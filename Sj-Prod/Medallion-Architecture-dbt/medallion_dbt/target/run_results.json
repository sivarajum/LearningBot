1:31.974589Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.017661094665527344, "adapter_response": {"_message": "OK"}, "message": null, "failures": 0, "unique_id": "test.medallion_dbt.silver_orders_valid_status", "compiled": true, "compiled_code": "/*\n  silver_orders_valid_status.sql\n  ------------------------------\n  SINGULAR TEST \u2014 Data Contract for Silver Orders status values.\n\n  Asserts that every order in the Silver layer has a status from the\n  canonical allowed set: PENDING, SHIPPED, DELIVERED, CANCELLED.\n\n  A non-empty result set means the test FAILS.\n\n  Why this matters:\n    - Gold CLV model filters on status = 'DELIVERED'. An unexpected status\n      value would silently corrupt business metrics.\n    - Enforcing this at Silver ensures Gold can rely on a clean contract.\n*/\n\nSELECT\n    order_id,\n    status,\n    _source_file,\n    _ingested_at\nFROM \"warehouse\".\"main_silver\".\"silver_orders\"\nWHERE status NOT IN ('PENDING', 'SHIPPED', 'DELIVERED', 'CANCELLED')", "relation_name": null, "batch_results": null}, {"status": "pass", "timing": [{"name": "compile", "started_at": "2026-06-06T13:01:31.961296Z", "completed_at": "2026-06-06T13:01:31.967485Z"}, {"name": "execute", "started_at": "2026-06-06T13:01:31.967801Z", "completed_at": "2026-06-06T13:01:31.976894Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.020413875579833984, "adapter_response": {"_message": "OK"}, "message": null, "failures": 0, "unique_id": "test.medallion_dbt.unique_bronze_orders_order_id.eec6e86d13", "compiled": true, "compiled_code": "\n    \n    \n\nselect\n    order_id as unique_field,\n    count(*) as n_records\n\nfrom \"warehouse\".\"main_bronze\".\"bronze_orders\"\nwhere order_id is not null\ngroup by order_id\nhaving count(*) > 1\n\n\n", "relation_name": null, "batch_results": null}, {"status": "pass", "timing": [{"name": "compile", "started_at": "2026-06-06T13:01:31.963687Z", "completed_at": "2026-06-06T13:01:31.967637Z"}, {"name": "e