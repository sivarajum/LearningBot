# Airflow Orchestration Platform — Environment Variables
# Copy to .env and adjust values as needed.

# API server settings
API_HOST=0.0.0.0
API_PORT=8000

# Streamlit UI settings
UI_PORT=8501

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8501

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# DAG and config directories (relative to project root)
DAGS_DIR=dags
CONFIG_DIR=config

# Maximum retry attempts for task execution in the simulator
MAX_RETRIES=2
