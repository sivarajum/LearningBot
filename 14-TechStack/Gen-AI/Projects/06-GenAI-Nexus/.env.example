# ============================================================
# GenAI Nexus — Environment Variables Template
# Copy to .env and fill in your API keys
# ============================================================

# --- LLM API Keys ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# --- AWS (for SageMaker + Bedrock) ---
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=us-east-1
AWS_SAGEMAKER_ROLE=arn:aws:iam::ACCOUNT:role/SageMakerRole

# --- App Config ---
LOG_LEVEL=INFO
DEMO_MODE=true          # true = use mocks (no API keys needed)
CHROMA_PATH=./data/chroma_db
KNOWLEDGE_BASE_PATH=./data/knowledge_base

# --- Model Config ---
DEFAULT_LLM=openai      # openai | claude | gemini
EMBEDDING_MODEL=openai  # openai | huggingface
OPENAI_MODEL=gpt-4o-mini
CLAUDE_MODEL=claude-3-haiku-20240307
GEMINI_MODEL=gemini-1.5-flash

# --- Local LLM (Ollama) ---
USE_LOCAL_LLM=false                     # Set true for fully local execution
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_CODE_MODEL=codellama:7b
OLLAMA_FAST_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Training Config ---
HF_MODEL_ID=distilbert-base-uncased
PEFT_BASE_MODEL=meta-llama/Llama-3.2-1B
QUANTIZE=false          # Enable INT8 quantization
